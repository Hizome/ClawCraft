{
  "name": "clawcraft-web",
  "private": true,
  "version": "0.0.1",
  "description": "ClawCraft desktop client built from the web frontend.",
  "engines": {
    "node": ">=20",
    "npm": ">=10",
    "bun": ">=1.3.0"
  },
  "author": {
    "name": "Harry",
    "email": "harry@example.com"
  },
  "homepage": "https://example.com/clawcraft",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:desktop": "concurrently -k \"next dev --port 3000\" \"wait-on tcp:3000 && electron .\"",
    "build": "next build --webpack",
    "build:desktop": "next build --webpack && npm_config_loglevel=silent npm_config_fund=false npm_config_audit=false electron-builder",
    "start": "next start --port 3000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mdx-m3-viewer": "^5.12.0",
    "next": "^16.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.clawcraft.desktop",
    "productName": "ClawCraft",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.png",
    "files": [
      "out/**/*",
      "electron/**/*",
      "build/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game",
      "icon": "build/icon.png"
    }
  }
}
